# --- Server ---
# If the frontend is served on 5000, use another port here (e.g. 5050) and set FRONTEND_URL to that origin.
PORT=5050
NODE_ENV=development

# --- Database ---
# Leave MONGODB_URI empty and/or set SKIP_DB=true to run the server without MongoDB (smoke test /health only).
SKIP_DB=true
# MONGODB_URI=mongodb://127.0.0.1:27017/switch-to-salesforce
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/switch-to-salesforce

# --- Auth (required before using POST /api/login and admin routes) ---
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# --- URLs ---
# Frontend origin(s) for CORS — comma-separated, no trailing slash (match your Live Server / dev server)
FRONTEND_URL=http://localhost:5000
# Public base URL of this API (optional locally; set in production)
SITE_URL=http://localhost:5050
