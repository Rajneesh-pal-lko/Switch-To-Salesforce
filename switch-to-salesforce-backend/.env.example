# --- Server ---
PORT=5000
NODE_ENV=development

# --- Database (add when you connect MongoDB; leave blank until then) ---
# MONGODB_URI=mongodb://127.0.0.1:27017/switch-to-salesforce
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/switch-to-salesforce

# --- Auth (required before using POST /api/login and admin routes) ---
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# --- URLs ---
# Frontend origin(s) for CORS — comma-separated, no trailing slash
FRONTEND_URL=http://localhost:5500
# Public base URL of this API (optional locally; set in production)
SITE_URL=http://localhost:5000
