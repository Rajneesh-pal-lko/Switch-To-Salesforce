# Site URL for Open Graph / canonical URLs (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Giscus — https://giscus.app (GitHub Discussions)
# Also required: install https://github.com/apps/giscus on this repo (not only env vars).
# Pre-filled for Rajneesh-pal-lko/Switch-To-Salesforce (Announcements category).
# Copy to .env.local for local dev. Add the same keys in Vercel → Environment Variables for production.
NEXT_PUBLIC_GISCUS_REPO=Rajneesh-pal-lko/Switch-To-Salesforce
NEXT_PUBLIC_GISCUS_REPO_ID=1200862581
NEXT_PUBLIC_GISCUS_CATEGORY=Announcements
NEXT_PUBLIC_GISCUS_CATEGORY_ID=DIC_kwDOR5O1dc4C6IRG

# Optional — footer “Contact” (no login on this site; opens visitor’s mail app or WhatsApp)
# NEXT_PUBLIC_CONTACT_EMAIL=you@example.com
# NEXT_PUBLIC_WHATSAPP_NUMBER=919876543210
# WhatsApp: country code + number, digits only (example above is India +91). Shown in page HTML via wa.me link.
