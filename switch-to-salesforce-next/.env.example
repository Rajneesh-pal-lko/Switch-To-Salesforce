# Site URL for Open Graph / canonical URLs (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Giscus (https://giscus.app) — requires GitHub Discussions on the repo
#
# 1. GitHub → repo Settings → General → Features → enable Discussions
# 2. Open https://giscus.app → enter repository → choose a discussion category
#    (e.g. Announcements, or create “Blog comments”) → copy the four values from the generated script
# 3. Copy this file to .env.local and paste CATEGORY / CATEGORY_ID from giscus.app
#
NEXT_PUBLIC_GISCUS_REPO=Rajneesh-pal-lko/Switch-To-Salesforce
NEXT_PUBLIC_GISCUS_REPO_ID=1200862581
NEXT_PUBLIC_GISCUS_CATEGORY=
NEXT_PUBLIC_GISCUS_CATEGORY_ID=
